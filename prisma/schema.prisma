generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified DateTime?
  image         String?
  role          String    @default("user")
  referralCode  String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  quizSubmissions  QuizSubmission[]
  profile          UserProfile?
  recommendations  Recommendation[]
  taskProgress     TaskProgress[]
  artifacts        GeneratedArtifact[]
}

model QuizSubmission {
  id             String   @id @default(cuid())
  userId         String
  formId         String?
  responseToken  String?
  answers        String
  rawAnswers     String?
  parsedAnswers  String?
  submittedAt    DateTime @default(now())
  source         String   @default("typeform")
  status         String   @default("pending_review")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserProfile {
  id                          String   @id @default(cuid())
  userId                      String   @unique
  traits                      String
  strengths                   String
  constraints                 String
  summary                     String?
  unfairAdvantageName         String?
  unfairAdvantageDescription  String?
  unfairAdvantageEvidence     String?
  unfairAdvantageWhy          String?
  linkedinSummary             String?
  onlinePresence              String?
  notableExperience           String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  user                        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BusinessPath {
  id                    String  @id @default(cuid())
  slug                  String  @unique
  name                  String
  headline              String
  description           String
  whoThisIs             String
  typicalBackground     String?
  workMode              String
  salesMotion           String
  failureMode           String?
  businessModel         String
  incomeRangeLow        Int
  incomeRangeHigh       Int
  timelineMonths        Int
  toolRecommendations   String
  nicheExamples         String?
  positioningTemplate   String?
  buyerProfile          String?
  outreachTemplate      String?
  gutCheckQuestions     String?
  order                 Int     @default(0)

  phases              Phase[]
  founderVideos       FounderVideo[]
  recommendationPaths RecommendationPath[]
}

model Recommendation {
  id              String   @id @default(cuid())
  userId          String
  primaryPathId   String
  confirmedPathId String?
  status          String   @default("pending")
  personalIntro   String?
  personalizedWhy String?
  pricingDetails  String?
  transitionPlan  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  paths RecommendationPath[]
}

model RecommendationPath {
  id               String @id @default(cuid())
  recommendationId String
  pathId           String
  rank             Int
  fitScore         Int?
  altDescription   String?
  altWhyConsider   String?
  altTradeoff      String?
  altRevenueRange  String?

  recommendation Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  path           BusinessPath   @relation(fields: [pathId], references: [id])

  @@unique([recommendationId, pathId])
}

model Phase {
  id             String       @id @default(cuid())
  name           String
  slug           String
  description    String       @default("")
  order          Int
  businessPathId String
  businessPath   BusinessPath @relation(fields: [businessPathId], references: [id])
  tasks          Task[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([businessPathId, order])
}

model Task {
  id           String  @id @default(cuid())
  phaseId      String
  slug         String  @unique
  title        String
  description  String
  whyItMatters String
  order        Int
  taskType     String
  timeEstimate String?

  phase     Phase             @relation(fields: [phaseId], references: [id])
  progress  TaskProgress[]
  artifacts GeneratedArtifact[]
}

model TaskProgress {
  id          String    @id @default(cuid())
  userId      String
  taskId      String
  status      String    @default("not_started")
  savedData   String?
  startedAt   DateTime?
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id])

  @@unique([userId, taskId])
}

model GeneratedArtifact {
  id        String   @id @default(cuid())
  userId    String
  taskId    String
  type      String
  content   String
  version   Int      @default(1)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id])
}

model FounderVideo {
  id          String  @id @default(cuid())
  pathId      String?
  youtubeUrl  String
  title       String
  description String?

  path BusinessPath? @relation(fields: [pathId], references: [id])
}
